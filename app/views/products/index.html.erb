<div class="container py-4">
  <%= render 'shared/search_form' %>
  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-12 col-md-6 col-lg-4">
        <%= render 'product_card', product: product %>
      </div>
    <% end %>
  </div>

  <div class="mt-4">
    <%= paginate @products, theme: 'bootstrap-5' %>
  </div>
</div>
