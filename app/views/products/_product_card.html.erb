<div class="card h-100 product-card">
  <% if product.images.attached? %>
    <%= link_to product_path(product) do %>
      <%= image_tag product.images.first.variant(resize_to_limit: [350,250]), class: 'card-img-top', alt: product.name %>
    <% end %>
  <% end %>
  <div class="card-body d-flex flex-column">
    <h5 class="card-title"><%= link_to product.name, product_path(product), class: 'text-decoration-none text-dark' %></h5>
    <p class="card-text"><%= truncate(product.description, length: 100) %></p>
    <div class="mt-auto">
      <p class="price">
        <% if product.on_sale? %>
          <strong class="text-danger"><%= number_to_currency(product.sale_price) %></strong>
          <small class="text-muted"><del><%= number_to_currency(product.price) %></del></small>
        <% else %>
          <strong><%= number_to_currency(product.price) %></strong>
        <% end %>
      </p>
      <%= link_to 'View Product', product_path(product), class: 'btn btn-primary w-100' %>
    </div>
  </div>
</div>
