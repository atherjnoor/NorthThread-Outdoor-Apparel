<div class="container py-5">
  <% breadcrumb_items = [{ label: 'Shop', path: products_path }] %>
  <% if @product.categories.any? %>
    <% breadcrumb_items << { label: @product.categories.first.name, path: category_path(@product.categories.first) } %>
  <% end %>
  <% breadcrumb_items << { label: @product.name, path: product_path(@product) } %>
  
  <%= render_breadcrumbs(breadcrumb_items) %>

  <div class="row">
    <div class="col-md-6">
      <% if @product.images.attached? %>
        <%= image_tag @product.images.first.variant(resize_to_limit: [600, 450]), class: 'img-fluid rounded' %>
      <% else %>
        <div class="placeholder bg-light p-5 text-center">No image available</div>
      <% end %>
    </div>

    <div class="col-md-6">
      <h1><%= @product.name %></h1>
      <p class="text-muted"><%= @product.categories.map(&:name).join(', ') %></p>
      <p><%= simple_format(@product.description) %></p>

      <div class="mb-3">
        <% if @product.on_sale? %>
          <h3 class="text-danger"><%= number_to_currency(@product.sale_price) %></h3>
          <small class="text-muted"><del><%= number_to_currency(@product.price) %></del></small>
        <% else %>
          <h3><%= number_to_currency(@product.price) %></h3>
        <% end %>
      </div>

      <%= form_with(url: cart_path, method: :post, local: true) do |f| %>
        <div class="mb-3">
          <%= f.label :quantity, 'Quantity' %>
          <%= f.number_field :quantity, value: 1, min: 1, class: 'form-control w-25' %>
        </div>
        <%= f.hidden_field :product_id, value: @product.id %>
        <%= f.submit 'Add to Cart', class: 'btn btn-success' %>
      <% end %>
    </div>
  </div>
</div>
