<div class="container py-4">
  <h1>Your Shopping Cart</h1>

  <% if @cart_items.empty? %>
    <p>Your cart is empty. <%= link_to 'Continue shopping', products_path %>.</p>
  <% else %>
    <table class="table table-bordered mt-3">
      <thead>
        <tr>
          <th>Product</th>
          <th>Unit price</th>
          <th>Quantity</th>
          <th>Line total</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr>
            <td><%= link_to item.product.name, product_path(item.product) %></td>
            <td><%= number_to_currency(item.product.display_price) %></td>
            <td>
              <%= form_with url: cart_path, method: :put, local: true do |f| %>
                <%= f.hidden_field :product_id, value: item.product.id %>
                <%= f.number_field :quantity, value: item.quantity, min: 1, class: 'form-control w-50 d-inline-block' %>
                <%= f.submit 'Update', class: 'btn btn-outline-primary btn-sm ms-2' %>
              <% end %>
            </td>
            <td><%= number_to_currency(item.line_total) %></td>
            <td>
              <%= button_to 'Remove', cart_path(product_id: item.product.id), method: :delete, class: 'btn btn-outline-danger btn-sm' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="row mt-4">
      <div class="col-md-6">
        <h5>Discount Code</h5>
        <%= form_with url: discount_codes_path, method: :post, local: true do |f| %>
          <div class="input-group mb-3">
            <%= f.text_field :code, name: :code, placeholder: 'Enter discount code', class: 'form-control' %>
            <button type="submit" class="btn btn-outline-secondary">Apply</button>
          </div>
        <% end %>

        <% if session[:discount_code_id] %>
          <% active_discount = DiscountCode.find_by(id: session[:discount_code_id]) %>
          <% if active_discount && active_discount.active? && (active_discount.expires_at.nil? || active_discount.expires_at > Time.zone.now) %>
            <div class="alert alert-success mt-2">
              Applied discount: <strong><%= active_discount.code %></strong> - <%= active_discount.discount_percentage %>% off
            </div>
          <% else %>
            <div class="alert alert-warning mt-2">Discount code no longer valid.</div>
          <% end %>
        <% end %>
      </div>

      <div class="col-md-6 text-end">
        <h4>Subtotal: <%= number_to_currency(@subtotal) %></h4>
        <% if user_signed_in? %>
          <%= link_to 'Proceed to Checkout', checkout_path, class: 'btn btn-success btn-lg mt-3' %>
        <% else %>
          <p class="mt-3"><%= link_to 'Sign in to checkout', new_user_session_path, class: 'btn btn-success btn-lg' %></p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
