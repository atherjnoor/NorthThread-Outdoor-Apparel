<h1>Order Confirmation</h1>
<p>Thank you for your order, <%= @user.first_name %>!</p>

<h2>Order #<%= @order.id %></h2>
<p>Status: <%= @order.status.upcase %></p>

<h3>Order Items</h3>
<ul>
  <% @order.order_items.each do |item| %>
    <li><%= item.product_name_snapshot %> - <%= item.quantity %> x $<%= item.unit_price_snapshot %></li>
  <% end %>
</ul>

<h3>Order Total</h3>
<p>Subtotal: $<%= @order.subtotal %></p>
<p>GST: $<%= @order.gst_amount %></p>
<p>PST: $<%= @order.pst_amount %></p>
<p>HST: $<%= @order.hst_amount %></p>
<p><strong>Grand Total: $<%= @order.grand_total %></strong></p>

<p>Visit <%= link_to 'your order', order_url(@order) %> to view details.</p>
