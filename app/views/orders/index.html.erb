<div class="container py-5">
  <h1>My Orders</h1>

  <% if @orders.empty? %>
    <p>You have no orders yet. <%= link_to 'Start shopping', products_path %>.</p>
  <% else %>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Date</th>
          <th>Items</th>
          <th>Grand Total</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td><%= order.id %></td>
            <td><%= order.created_at.strftime('%b %d, %Y') %></td>
            <td><%= order.order_items.sum(:quantity) %></td>
            <td><%= number_to_currency(order.grand_total) %></td>
            <td>
              <span class="badge bg-<%= order.status == 'new' ? 'warning' : order.status == 'paid' ? 'success' : 'info' %>">
                <%= order.status.upcase %>
              </span>
            </td>
            <td><%= link_to 'View', order_path(order), class: 'btn btn-sm btn-outline-primary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
