<%= form_with url: products_path, method: :get, local: true, class: 'd-flex mb-4' do |f| %>
  <%= f.text_field :keyword, value: params[:keyword], placeholder: 'Search products', class: 'form-control me-2' %>
  <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), include_blank: 'All categories', class: 'form-select me-2' %>
  <%= f.submit 'Search', class: 'btn btn-secondary' %>
<% end %>
