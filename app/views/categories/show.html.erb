<div class="container py-4">
  <%= render_breadcrumbs([{ label: 'Categories', path: categories_path }, { label: @category.name, path: category_path(@category) }]) %>
  
  <h1><%= @category.name %></h1>
  <p><%= @category.description %></p>

  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-12 col-md-6 col-lg-4">
        <%= render 'products/product_card', product: product %>
      </div>
    <% end %>
  </div>

  <div class="mt-4"><%= paginate @products, theme: 'bootstrap-5' %></div>
</div>
