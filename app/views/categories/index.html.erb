<div class="container py-4">
  <h1>Categories</h1>
  <div class="row">
    <% @categories.each do |category| %>
      <div class="col-12 col-md-6 col-lg-4 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= link_to category.name, category_path(category), class: 'text-decoration-none' %></h5>
            <p class="card-text"><%= truncate(category.description, length: 110) %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
