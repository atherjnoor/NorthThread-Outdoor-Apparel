<div class="container py-5">
  <h1>Edit Address</h1>

  <%= form_with(model: @address, local: true) do |f| %>
    <div class="mb-3">
      <%= f.label :address_line1, 'Street Address' %>
      <%= f.text_field :address_line1, class: 'form-control', placeholder: '123 Main St' %>
      <% if @address.errors[:address_line1].any? %>
        <small class="text-danger"><%= @address.errors[:address_line1].first %></small>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :address_line2, 'Apt/Suite (optional)' %>
      <%= f.text_field :address_line2, class: 'form-control' %>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= f.label :city, 'City' %>
        <%= f.text_field :city, class: 'form-control' %>
        <% if @address.errors[:city].any? %>
          <small class="text-danger"><%= @address.errors[:city].first %></small>
        <% end %>
      </div>
      <div class="col-md-6 mb-3">
        <%= f.label :postal_code, 'Postal Code' %>
        <%= f.text_field :postal_code, class: 'form-control' %>
        <% if @address.errors[:postal_code].any? %>
          <small class="text-danger"><%= @address.errors[:postal_code].first %></small>
        <% end %>
      </div>
    </div>

    <div class="mb-3">
      <%= f.label :province_id, 'Province' %>
      <%= f.collection_select :province_id, @provinces, :id, :name, class: 'form-select' %>
      <% if @address.errors[:province_id].any? %>
        <small class="text-danger"><%= @address.errors[:province_id].first %></small>
      <% end %>
    </div>

    <div class="mb-3 form-check">
      <%= f.check_box :is_default, class: 'form-check-input' %>
      <%= f.label :is_default, 'Set as default address', class: 'form-check-label' %>
    </div>

    <%= f.submit 'Update Address', class: 'btn btn-success' %>
    <%= link_to 'Cancel', addresses_path, class: 'btn btn-outline-secondary' %>
  <% end %>
</div>
