<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h3>Payment for Order #<%= @order.id %></h3>
        </div>
        <div class="card-body">
          <h5 class="card-title">Order Summary</h5>
          <table class="table table-sm">
            <tr>
              <td>Subtotal:</td>
              <td><strong><%= number_to_currency(@order.subtotal) %></strong></td>
            </tr>
            <% if @order.discount_amount.to_f > 0 %>
              <tr>
                <td>Discount:</td>
                <td><strong>-<%= number_to_currency(@order.discount_amount) %></strong></td>
              </tr>
            <% end %>
            <tr>
              <td>Tax (GST/PST/HST):</td>
              <td><strong><%= number_to_currency(@order.total_tax) %></strong></td>
            </tr>
            <tr style="border-top: 2px solid #dee2e6; font-weight: bold;">
              <td>Total Due:</td>
              <td><strong><%= number_to_currency(@order.grand_total) %></strong></td>
            </tr>
          </table>

          <div class="alert alert-info mt-4">
            <strong>Stripe Sandbox Mode</strong><br>
            This is a test payment. Use any test card number to proceed.
            <br><small>Test Card: 4242 4242 4242 4242</small>
          </div>

          <%= form_with url: order_payment_path(@order), method: :post, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :card_holder, "Cardholder Name" %>
              <%= f.text_field :card_holder, class: 'form-control', placeholder: 'John Doe', required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :card_number, "Card Number" %>
              <%= f.text_field :card_number, class: 'form-control', placeholder: '4242 4242 4242 4242', required: true, maxlength: 19 %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :expiry, "Expiry (MM/YY)" %>
                <%= f.text_field :expiry, class: 'form-control', placeholder: '12/25', required: true, maxlength: 5 %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :cvc, "CVC" %>
                <%= f.text_field :cvc, class: 'form-control', placeholder: '123', required: true, maxlength: 4 %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.submit "Pay #{number_to_currency(@order.grand_total)}", class: 'btn btn-success btn-lg w-100' %>
            </div>
          <% end %>

          <%= link_to "Cancel", order_path(@order), class: 'btn btn-secondary btn-sm w-100 mt-2' %>
        </div>
      </div>
    </div>
  </div>
</div>
